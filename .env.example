# FSS local development environment

NODE_ENV=development
TZ=Asia/Seoul

# CORS
CORS_ORIGIN=http://localhost:5173

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fss
DB_USER=fss_user
DB_PASS=fss_secret_2024

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO object storage
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=fss_admin
MINIO_ROOT_PASSWORD=fss_minio_secret_2024
MINIO_BUCKET=fss-uploads
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

# API
PORT=3000
JWT_SECRET=fss-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# Web
VITE_API_URL=http://localhost/api

# Optional external database integration
EXT_DB_HOST=
EXT_DB_PORT=5432
EXT_DB_NAME=
EXT_DB_USER=
EXT_DB_PASS=

# Optional factory-backend HTTP API for digital twin export
FACTORY_API_URL=
FACTORY_SCHEMA_NAME=
FSS_API_KEY=

# Optional external S3-compatible storage for digital twin export
EXT_S3_ENDPOINT=
EXT_S3_ACCESS_KEY=
EXT_S3_SECRET_KEY=
EXT_S3_BUCKET=dt-storage
EXT_S3_REGION=us-east-1

# Development-only escape hatch for self-signed TLS endpoints.
# Leave empty unless you explicitly need it in a local .env file.
NODE_TLS_REJECT_UNAUTHORIZED=
