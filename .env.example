cat > .env.example << 'EOF'
# ============================================
# FSS нҷҳкІҪліҖмҲҳ
# ============================================

# в”Җв”Җ кіөнҶө в”Җв”Җ
NODE_ENV=development
TZ=Asia/Seoul

# в”Җв”Җ PostgreSQL в”Җв”Җ
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fss
DB_USER=fss_user
DB_PASSWORD=fss_secret_2024

# в”Җв”Җ Redis в”Җв”Җ
REDIS_HOST=redis
REDIS_PORT=6379

# в”Җв”Җ MinIO (мҳӨлёҢм қнҠё мҠӨнҶ лҰ¬м§Җ) в”Җв”Җ
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=fss_admin
MINIO_ROOT_PASSWORD=fss_minio_secret_2024
MINIO_BUCKET=fss-assets
MINIO_USE_SSL=false

# в”Җв”Җ мҷёл¶Җ DB (factory-backend, Tailscale) в”Җв”Җ
EXT_DB_HOST=
EXT_DB_PORT=5432
EXT_DB_NAME=
EXT_DB_USER=
EXT_DB_PASS=

# в”Җв”Җ factory-backend HTTP API (FSS м—җм…Ӣ м „мҶЎмҡ©) в”Җв”Җ
FACTORY_API_URL=
FSS_API_KEY=

# в”Җв”Җ D.T мҷёл¶Җ мҠӨнҶ лҰ¬м§Җ (S3 нҳёнҷҳ) в”Җв”Җ
EXT_S3_ENDPOINT=
EXT_S3_ACCESS_KEY=
EXT_S3_SECRET_KEY=
EXT_S3_BUCKET=dt-storage
EXT_S3_REGION=us-east-1

# в”Җв”Җ JWT в”Җв”Җ
JWT_SECRET=fss-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# в”Җв”Җ API в”Җв”Җ
API_PORT=3000

# в”Җв”Җ н”„лҹ°нҠём—”л“ң в”Җв”Җ
VITE_API_URL=http://localhost/api
EOF




