cat > .env.example << 'EOF'
# ============================================
# FSS 환경변수
# ============================================

# ── 공통 ──
NODE_ENV=development
TZ=Asia/Seoul

# ── PostgreSQL ──
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fss
DB_USER=fss_user
DB_PASSWORD=fss_secret_2024

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── MinIO (오브젝트 스토리지) ──
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=fss_admin
MINIO_ROOT_PASSWORD=fss_minio_secret_2024
MINIO_BUCKET=fss-assets
MINIO_USE_SSL=false

# ── JWT ──
JWT_SECRET=fss-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# ── API ──
API_PORT=3000

# ── 프런트엔드 ──
VITE_API_URL=http://localhost/api
EOF